## Copy to `.env` (do not commit secrets) and adjust values as needed.

# Server
PORT=3000

# Admin auth
ADMIN_PASSWORD=admin123
TOKEN_SECRET=super-secret-token-123

# Upload limits (used by POST /api/upload base64 payloads)
UPLOAD_MAX_BYTES=2097152

# Log rotation (used by logs.txt rotation)
LOG_ROTATE_MAX_BYTES=1048576

PORT=3000
ADMIN_PASSWORD=your_secure_password_here
TOKEN_SECRET=your_secure_token_secret_here